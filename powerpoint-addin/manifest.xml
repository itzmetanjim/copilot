<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1" 
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
           xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0" 
           xmlns:ov="http://schemas.microsoft.com/office/taskpaneappversionoverrides" 
           xsi:type="TaskPaneApp">

  <!-- Begin Basic Settings: Add-in metadata, used for all versions of Office unless override provided. -->
  <!-- IMPORTANT! Id must be unique for your add-in, if you reuse this manifest ensure that you change this id to a new GUID. -->
  <Id>565bb156-55f7-40b5-87e3-7715f0fcc7ff</Id>

  <!--Version. Updates from the store only get triggered if there is a version change. -->
  <Version>1.0.0.0</Version>
  <ProviderName>Odin AI Assistant Suite</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <!-- The display name of your add-in. Used on the store and various places of the Office UI such as the add-ins dialog. -->
  <DisplayName DefaultValue="Odin PowerPoint Assistant" />
  <Description DefaultValue="AI-powered presentation assistant for Microsoft PowerPoint with slide generation, speaker notes, and design capabilities." />
  <!-- Icon for your add-in. Used on installation screens and the add-ins dialog. -->
  <IconUrl DefaultValue="https://itzmetanjim.github.io/copilot/powerpoint/assets/icon-32.png" />
  <HighResolutionIconUrl DefaultValue="https://itzmetanjim.github.io/copilot/powerpoint/assets/icon-80.png" />

  <!--If you plan to submit this add-in to the Office Store, uncomment the SupportUrl element below-->
  <SupportUrl DefaultValue="https://github.com/itzmetanjim/copilot" />

  <!-- Domains that will be allowed when navigating. For example, if you use ShowTaskpane and then have an href link, navigation will only be allowed if the domain is on this list. -->
  <AppDomains>
    <AppDomain>https://itzmetanjim.github.io</AppDomain>
    <AppDomain>https://generativelanguage.googleapis.com</AppDomain>
    <AppDomain>https://api.cerebras.ai</AppDomain>
  </AppDomains>
  <!--End Basic Settings. -->

  <!--Begin TaskPane Mode integration. This section is used if there are no VersionOverrides or if the Office client version does not support add-in commands. -->
  <Hosts>
    <Host Name="Presentation" />
  </Hosts>
  <DefaultSettings>
    <SourceLocation DefaultValue="https://itzmetanjim.github.io/copilot/powerpoint/taskpane.html" />
  </DefaultSettings>
  <!--End TaskPane Mode integration.  -->

  <Permissions>ReadWriteDocument</Permissions>

  <!-- Begin Add-in Commands Mode integration. -->
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="VersionOverridesV1_0">

    <!-- The Hosts node is required. -->
    <Hosts>
      <!-- Each host can have a different set of commands. -->
      <!-- PowerPoint host is Presentation, Word host is Document, and Excel host is Workbook. -->
      <!-- Make sure the hosts you override match the hosts declared in the top level <Hosts> node. -->
      <Host xsi:type="Presentation">
        <!-- Form factor. Currently only DesktopFormFactor is supported. -->
        <DesktopFormFactor>
          <!--"This code enables a customizable message to be displayed when the add-in is loaded successfully upon individual install."-->
          <GetStarted>
            <!-- Title of the Getting Started callout. resid points to a ShortString resource -->
            <Title resid="OdinPPT.GetStartedTitle"/>
            <!-- Description of the Getting Started callout. resid points to a LongString resource -->
            <Description resid="OdinPPT.GetStartedDescription"/>
            <!-- Point to a url resource which details how the add-in should be used. -->
            <LearnMoreUrl resid="OdinPPT.GetStartedLearnMoreUrl"/>
          </GetStarted>
          <!-- Function file is a HTML page that includes the JavaScript where functions for ExecuteAction will be called. 
               Think of the FunctionFile as the code behind ExecuteFunction. -->
          <FunctionFile resid="OdinPPT.DesktopFunctionFile"/>

          <!-- PrimaryCommandSurface is the main Office Ribbon. -->
          <ExtensionPoint xsi:type="PrimaryCommandSurface">
            <!-- Use OfficeTab to extend an existing Tab. Use CustomTab to create a new tab. -->
            <OfficeTab id="TabHome">
              <!-- Ensure you provide a unique id for the group. Recommendation for any IDs is to namespace using your company name. -->
              <Group id="OdinPPT.Group1">
                <!-- Label for your group. resid must point to a ShortString resource. -->
                <Label resid="OdinPPT.Group1Label" />
                <!-- Icons. Required sizes 16,32,80, optional 20, 24, 40, 48, 64. Strongly recommended to provide all sizes for great UX. -->
                <!-- Use PNG icons. All URLs on the resources section must use HTTPS. -->
                <Icon>
                  <bt:Image size="16" resid="OdinPPT.tpicon_16x16" />
                  <bt:Image size="32" resid="OdinPPT.tpicon_32x32" />
                  <bt:Image size="80" resid="OdinPPT.tpicon_80x80" />
                </Icon>

                <!-- Control. It can be of type "Button" or "Menu". -->
                <Control xsi:type="Button" id="OdinPPT.TaskpaneButton">
                  <Label resid="OdinPPT.TaskpaneButton.Label" />
                  <Supertip>
                    <!-- ToolTip title. resid must point to a ShortString resource. -->
                    <Title resid="OdinPPT.TaskpaneButton.Label" />
                    <!-- ToolTip description. resid must point to a LongString resource. -->
                    <Description resid="OdinPPT.TaskpaneButton.Tooltip" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="OdinPPT.tpicon_16x16" />
                    <bt:Image size="32" resid="OdinPPT.tpicon_32x32" />
                    <bt:Image size="80" resid="OdinPPT.tpicon_80x80" />
                  </Icon>

                  <!-- This is what happens when the command is triggered (E.g. click on the Ribbon). Supported actions are ExecuteFunction or ShowTaskpane. -->
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>ButtonId1</TaskpaneId>
                    <!-- Provide a url resource id for the location that will be displayed on the task pane. -->
                    <SourceLocation resid="OdinPPT.Taskpane.Url" />
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>

    <!-- You can use resources across hosts and form factors. -->
    <Resources>
      <bt:Images>
        <bt:Image id="OdinPPT.tpicon_16x16" DefaultValue="https://itzmetanjim.github.io/copilot/powerpoint/assets/icon-16.png" />
        <bt:Image id="OdinPPT.tpicon_32x32" DefaultValue="https://itzmetanjim.github.io/copilot/powerpoint/assets/icon-32.png" />
        <bt:Image id="OdinPPT.tpicon_80x80" DefaultValue="https://itzmetanjim.github.io/copilot/powerpoint/assets/icon-80.png" />
      </bt:Images>
      <bt:Urls>
        <bt:Url id="OdinPPT.Taskpane.Url" DefaultValue="https://itzmetanjim.github.io/copilot/powerpoint/taskpane.html" />
        <bt:Url id="OdinPPT.GetStartedLearnMoreUrl" DefaultValue="https://github.com/itzmetanjim/copilot" />
        <bt:Url id="OdinPPT.DesktopFunctionFile" DefaultValue="https://itzmetanjim.github.io/copilot/powerpoint/function-file.html" />
      </bt:Urls>
      <!-- ShortStrings max characters==125. -->
      <bt:ShortStrings>
        <bt:String id="OdinPPT.TaskpaneButton.Label" DefaultValue="Odin Assistant" />
        <bt:String id="OdinPPT.Group1Label" DefaultValue="Odin AI" />
        <bt:String id="OdinPPT.GetStartedTitle" DefaultValue="Get started with Odin PowerPoint Assistant!" />
      </bt:ShortStrings>
      <!-- LongStrings max characters==250. -->
      <bt:LongStrings>
        <bt:String id="OdinPPT.TaskpaneButton.Tooltip" DefaultValue="Open Odin AI Assistant for PowerPoint. Create presentations, generate speaker notes, and design slides with AI." />
        <bt:String id="OdinPPT.GetStartedDescription" DefaultValue="Your AI-powered presentation assistant is ready! Click the Odin Assistant button to start creating amazing presentations." />
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
  <!-- End Add-in Commands Mode integration. -->

</OfficeApp>