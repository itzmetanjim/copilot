<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1" 
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
           xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0" 
           xmlns:ov="http://schemas.microsoft.com/office/taskpaneappversionoverrides" 
           xsi:type="TaskPaneApp">

  <!-- Begin Basic Settings: Add-in metadata, used for all versions of Office unless override provided. -->
  <!-- IMPORTANT! Id must be unique for your add-in, if you reuse this manifest ensure that you change this id to a new GUID. -->
  <Id>12345678-1234-1234-1234-123456789abc</Id>

  <!--Version. Updates from the store only get triggered if there is a version change. -->
  <Version>1.0.0.0</Version>
  <ProviderName>Odin AI Assistant Suite</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <!-- The display name of your add-in. Used on the store and various places of the Office UI such as the add-ins dialog. -->
  <DisplayName DefaultValue="Odin Word Assistant" />
  <Description DefaultValue="AI-powered writing assistant for Microsoft Word with document generation, summarization, and editing capabilities." />
  <!-- Icon for your add-in. Used on installation screens and the add-ins dialog. -->
  <IconUrl DefaultValue="https://itzmetanjim.github.io/copilot/word/assets/icon-32.png" />
  <HighResolutionIconUrl DefaultValue="https://itzmetanjim.github.io/copilot/word/assets/icon-80.png" />

  <!--If you plan to submit this add-in to the Office Store, uncomment the SupportUrl element below-->
  <SupportUrl DefaultValue="https://github.com/itzmetanjim/copilot" />

  <!-- Domains that will be allowed when navigating. For example, if you use ShowTaskpane and then have an href link, navigation will only be allowed if the domain is on this list. -->
  <AppDomains>
    <AppDomain>https://itzmetanjim.github.io</AppDomain>
    <AppDomain>https://generativelanguage.googleapis.com</AppDomain>
    <AppDomain>https://api.cerebras.ai</AppDomain>
  </AppDomains>
  <!--End Basic Settings. -->

  <!--Begin TaskPane Mode integration. This section is used if there are no VersionOverrides or if the Office client version does not support add-in commands. -->
  <Hosts>
    <Host Name="Document" />
  </Hosts>
  <DefaultSettings>
    <SourceLocation DefaultValue="https://itzmetanjim.github.io/copilot/word/taskpane.html" />
  </DefaultSettings>
  <!--End TaskPane Mode integration.  -->

  <Permissions>ReadWriteDocument</Permissions>

  <!-- Begin Add-in Commands Mode integration. -->
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="VersionOverridesV1_0">

    <!-- The Hosts node is required. -->
    <Hosts>
      <!-- Each host can have a different set of commands. -->
      <!-- Excel host is Workbook, Word host is Document, and PowerPoint host is Presentation. -->
      <!-- Make sure the hosts you override match the hosts declared in the top level <Hosts> node. -->
      <Host xsi:type="Document">
        <!-- Form factor. Currently only DesktopFormFactor is supported. -->
        <DesktopFormFactor>
          <!--"This code enables a customizable message to be displayed when the add-in is loaded successfully upon individual install."-->
          <GetStarted>
            <!-- Title of the Getting Started callout. resid points to a ShortString resource -->
            <Title resid="Odin.GetStartedTitle"/>
            <!-- Description of the Getting Started callout. resid points to a LongString resource -->
            <Description resid="Odin.GetStartedDescription"/>
            <!-- Point to a url resource which details how the add-in should be used. -->
            <LearnMoreUrl resid="Odin.GetStartedLearnMoreUrl"/>
          </GetStarted>
          <!-- Function file is a HTML page that includes the JavaScript where functions for ExecuteAction will be called. 
               Think of the FunctionFile as the code behind ExecuteFunction. -->
          <FunctionFile resid="Odin.DesktopFunctionFile"/>

          <!-- PrimaryCommandSurface is the main Office Ribbon. -->
          <ExtensionPoint xsi:type="PrimaryCommandSurface">
            <!-- Use OfficeTab to extend an existing Tab. Use CustomTab to create a new tab. -->
            <OfficeTab id="TabHome">
              <!-- Ensure you provide a unique id for the group. Recommendation for any IDs is to namespace using your company name. -->
              <Group id="Odin.Group1">
                <!-- Label for your group. resid must point to a ShortString resource. -->
                <Label resid="Odin.Group1Label" />
                <!-- Icons. Required sizes 16,32,80, optional 20, 24, 40, 48, 64. Strongly recommended to provide all sizes for great UX. -->
                <!-- Use PNG icons. All URLs on the resources section must use HTTPS. -->
                <Icon>
                  <bt:Image size="16" resid="Odin.tpicon_16x16" />
                  <bt:Image size="32" resid="Odin.tpicon_32x32" />
                  <bt:Image size="80" resid="Odin.tpicon_80x80" />
                </Icon>

                <!-- Control. It can be of type "Button" or "Menu". -->
                <Control xsi:type="Button" id="Odin.TaskpaneButton">
                  <Label resid="Odin.TaskpaneButton.Label" />
                  <Supertip>
                    <!-- ToolTip title. resid must point to a ShortString resource. -->
                    <Title resid="Odin.TaskpaneButton.Label" />
                    <!-- ToolTip description. resid must point to a LongString resource. -->
                    <Description resid="Odin.TaskpaneButton.Tooltip" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Odin.tpicon_16x16" />
                    <bt:Image size="32" resid="Odin.tpicon_32x32" />
                    <bt:Image size="80" resid="Odin.tpicon_80x80" />
                  </Icon>

                  <!-- This is what happens when the command is triggered (E.g. click on the Ribbon). Supported actions are ExecuteFunction or ShowTaskpane. -->
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>ButtonId1</TaskpaneId>
                    <!-- Provide a url resource id for the location that will be displayed on the task pane. -->
                    <SourceLocation resid="Odin.Taskpane.Url" />
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>

    <!-- You can use resources across hosts and form factors. -->
    <Resources>
      <bt:Images>
        <bt:Image id="Odin.tpicon_16x16" DefaultValue="https://itzmetanjim.github.io/copilot/word/assets/icon-16.png" />
        <bt:Image id="Odin.tpicon_32x32" DefaultValue="https://itzmetanjim.github.io/copilot/word/assets/icon-32.png" />
        <bt:Image id="Odin.tpicon_80x80" DefaultValue="https://itzmetanjim.github.io/copilot/word/assets/icon-80.png" />
      </bt:Images>
      <bt:Urls>
        <bt:Url id="Odin.Taskpane.Url" DefaultValue="https://itzmetanjim.github.io/copilot/word/taskpane.html" />
        <bt:Url id="Odin.GetStartedLearnMoreUrl" DefaultValue="https://github.com/itzmetanjim/copilot" />
        <bt:Url id="Odin.DesktopFunctionFile" DefaultValue="https://itzmetanjim.github.io/copilot/word/function-file.html" />
      </bt:Urls>
      <!-- ShortStrings max characters==125. -->
      <bt:ShortStrings>
        <bt:String id="Odin.TaskpaneButton.Label" DefaultValue="Odin Assistant" />
        <bt:String id="Odin.Group1Label" DefaultValue="Odin AI" />
        <bt:String id="Odin.GetStartedTitle" DefaultValue="Get started with Odin Word Assistant!" />
      </bt:ShortStrings>
      <!-- LongStrings max characters==250. -->
      <bt:LongStrings>
        <bt:String id="Odin.TaskpaneButton.Tooltip" DefaultValue="Open Odin AI Assistant for Word. Generate, edit, and improve your documents with AI." />
        <bt:String id="Odin.GetStartedDescription" DefaultValue="Your AI-powered writing assistant is ready! Click the Odin Assistant button to start generating, editing, and improving your documents." />
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
  <!-- End Add-in Commands Mode integration. -->

</OfficeApp>